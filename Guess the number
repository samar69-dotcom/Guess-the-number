
print()import random

def guess_the_number():
    # 1. Generate a random number between 1 and 100
    secret_number = random.randint(1, 100)
    attempts = 0
    
    print("Welcome to the Guess the Number game!")
    print("I'm thinking of a number between 1 and 100.")

    # 2. Start a loop that runs until the player guesses correctly
    while True:
        try:
            # 3. Get user input and convert it to an integer
            user_guess = int(input("Enter your guess: "))
            attempts += 1

            # 4. Compare the guess and provide feedback
            if user_guess < secret_number:
                print("Too low! Try a higher number.")
            elif user_guess > secret_number:
                print("Too high! Try a lower number.")
            else:
                print(f"Congratulations! You found it in {attempts} attempts.")
                break # Exit the loop
        except ValueError:
            print("Invalid input! Please enter a whole number.")

if __name__ == "__main__":
    guess_the_number()
